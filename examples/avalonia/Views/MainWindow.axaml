<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SkyleAvaloniaExample.Views"
        x:Class="SkyleAvaloniaExample.Views.MainWindow"
        Width="820" Height="760"
        MinWidth="520" MinHeight="480"
        Title="Skyle — Avalonia Example"
        Background="#1B1B1F">

    <Window.Styles>
        <!-- Segmented control: two joined RadioButtons -->
        <Style Selector="RadioButton.segment">
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="seg" Background="Transparent" CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.segment:checked /template/ Border#seg">
            <Setter Property="Background" Value="#3D8BFD" />
        </Style>
        <Style Selector="RadioButton.segment:checked">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="RadioButton.segment:pointerover /template/ Border#seg">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Top bar: connection indicator + device info -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="14" Height="14" Fill="{Binding ConnectionBrush}" />
                <TextBlock Text="{Binding ConnectionLabel}" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="{Binding DeviceInfo}" FontSize="12"
                       Foreground="#9A9AA0" VerticalAlignment="Center" />
        </Grid>

        <!-- Segmented control -->
        <Border Grid.Row="1" Background="#2A2A30" CornerRadius="8" Padding="3"
                HorizontalAlignment="Center" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <RadioButton Classes="segment" GroupName="view" Content="Positioning"
                             IsChecked="{Binding IsPositioningSelected, Mode=TwoWay}" />
                <RadioButton Classes="segment" GroupName="view" Content="Video"
                             IsChecked="{Binding IsVideoSelected, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <!-- Content host: positioning OR video -->
        <Panel Grid.Row="2">
            <views:PositioningView Source="{Binding Positioning}"
                                   IsVisible="{Binding ShowPositioning}" />
            <views:VideoView Source="{Binding Frame}"
                             IsVisible="{Binding ShowVideo}" />
        </Panel>

        <!-- Gaze readout -->
        <Border Grid.Row="3" Background="#2A2A30" CornerRadius="8" Padding="14,10" Margin="0,14,0,0">
            <TextBlock Text="{Binding GazeText}" FontSize="16" FontFamily="monospace"
                       Foreground="White" />
        </Border>

    </Grid>
</Window>
